{
  "name": "cross-border-erp",
  "version": "1.0.0",
  "description": "跨境电商ERP：虾皮泰国站 + 1688同款匹配系统",
  "private": true,
  "main": "main.js",
  "scripts": {
    "launch": "node scripts/launch.js",
    "postinstall": "node scripts/ensure-runtime.js",
    "dev": "concurrently \"node server/app.js\" \"node scripts/run-vite.js --port 5173\"",
    "server": "node server/app.js",
    "build": "node scripts/run-vite.js build",
    "electron:dev": "cross-env NODE_ENV=development node scripts/run-electron.js .",
    "electron:prod": "npm run build && node scripts/run-electron.js .",
    "start": "npm run build && node scripts/run-electron.js .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "electron": "^28.2.0",
    "express": "^4.18.2",
    "node-xlsx": "^0.23.0",
    "puppeteer": "^21.11.0",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "element-plus": "^2.6.1",
    "pinia": "^2.1.7",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "vue": "^3.4.19",
    "vue-router": "^4.3.0"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
